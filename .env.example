# Copy this file to .env and adjust values
# Backend: dual | llama_cpp | transformers
LLM_BACKEND=dual
LLM_MODE=auto
FAST_BACKEND=transformers
SMART_BACKEND=llama_cpp

# llama.cpp
LLAMA_CPP_MODEL_PATH=./models/llama-3-8b-instruct.Q4_K_M.gguf
LLAMA_CPP_N_CTX=4096
LLAMA_CPP_N_THREADS=8
# 0 = CPU only, -1 = offload all supported layers to GPU
LLAMA_CPP_N_GPU_LAYERS=-1

# transformers
HF_MODEL_ID=Qwen/Qwen2.5-Coder-1.5B-Instruct
HF_DEVICE_MAP=auto

# Agent behavior
MAX_TOKENS=512
TEMPERATURE=0.2
MEMORY_DIR=./data/chroma
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:5173,http://localhost:5173
