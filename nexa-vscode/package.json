{
  "name": "nexa-vscode",
  "displayName": "Nexa AI IDE",
  "description": "Cursor-like local AI workflows for VS Code using NexaAgent backend.",
  "version": "0.1.2",
  "publisher": "nexaai",
  "license": "UNLICENSED",
  "icon": "media/nexa.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "nexa.askAI",
        "title": "Nexa: Ask AI"
      },
      {
        "command": "nexa.editSelection",
        "title": "Nexa: Edit Selection"
      },
      {
        "command": "nexa.explainFile",
        "title": "Nexa: Explain Current File"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nexa",
          "title": "Nexa",
          "icon": "media/nexa.svg"
        }
      ]
    },
    "views": {
      "nexa": [
        {
          "id": "nexa.chatView",
          "name": "Nexa Chat",
          "icon": "media/nexa.svg",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Nexa",
      "properties": {
        "nexa.apiBaseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8000",
          "description": "Base URL for local NexaAgent API backend."
        },
        "nexa.mode": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "fast",
            "smart"
          ],
          "description": "Response mode for Nexa. Auto routes simple prompts to fast mode and deeper prompts to smart mode."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.2",
    "@vscode/vsce": "^3.1.0"
  }
}
